  "blocks": [
    {
      "type": "hero",
      "data": {
        "kicker": "Dinner",
        "summary": "Yogurt marinated chicken with a buttery tomato sauce",
        "backgroundImage": "https://1drv.ms/i/c/453dc263ab1fb587/IQRsn5nBLM0USpfs8jvfouR9AcIPOOsjnbjWscJPN4SXVHs?width=4271&height=5095"
      }
    },
    {
      "type": "ingredients",
      "data": {
        "items": [
          "2 tablespoons butter",
          "1 tablespoon neural oil",
          "1 medium onion",
          "4 garlic cloves",
          "1 can tomatoes",
          "1 teaspoon paprika",
          "1 teaspoon garam masala",
          "1/2 teaspoon cumin",
          "2 teaspoon salt",
          "1 tablespoon sugar",
          "1/2 cup heavy cream",
          "fresh cilantro"
        ]
      }
    },
    {
      "type": "instructions",
      "data": {
        "steps": [
          "Heat butter and oil",
          "Cook onion until soft, about 8 minutes",
          "Add garlic and cook until fragrant",
          "Add tomatoes and seasoning",
          "Simmer 15-20 minutes",
          "Add in chicken and heavy cream",
          "Simmer 10-15 minutes more",
          "Serve and garnish with cilantro and cream"
        ]
      }
    },
