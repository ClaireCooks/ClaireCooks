        "summary": "Yogurt marinated chicken with a buttery tomato sauce",
        "backgroundImage": "https://pub-b219213e36074f04bcc0424ce16a0ffb.r2.dev/recipes/murgh-makhani/hero/murgh-makhani-hero-20260619t190042z.webp"
      }
    },
    {
      "type": "ingredients",
      "data": {
        "items": [
          "2 tablespoons butter",
          "1 tablespoon neural oil",
          "1 medium onion",
          "4 garlic cloves",
          "1 can tomatoes",
          "1 teaspoon paprika",
          "1 teaspoon garam masala",
          "1/2 teaspoon cumin",
          "2 teaspoon salt",
          "1 tablespoon sugar",
          "1/2 cup heavy cream",
          "fresh cilantro"
        ],
        "image": ""
      }
    },
    {
      "type": "instructions",
      "data": {
        "steps": [
          "Heat butter and oil",
          "Cook onion until soft, about 8 minutes",
          "Add garlic and cook until fragrant",
          "Add tomatoes and seasoning",
          "Simmer 15-20 minutes",
          "Add in chicken and heavy cream",
          "Simmer 10-15 minutes more",
          "Serve and garnish with cilantro and cream"
        ]
      }
    },
